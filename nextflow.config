params {
  help = false

  // Output directory
  outdir = './results'

  // Reference genome to map against when looking for iSNV
  reference = false 

  // Either input reads as a glob pattern or as a tab delimited file
  reads = false
}

profiles {
  stjude {
    includeConfig 'configs/stjude.config'
  }
}

process {
  publishDir = "$params.outdir"
  withName: 'FASTQC'          { time = '24h'; memory = '128 GB'; cpus = 12; env.JAVA_TOOL_OPTIONS='-Xmx100g'; publishDir = "${params.outdir}/fastqc" }
  withName: 'MULTIQC'             { publishDir = [ path: "${params.outdir}/multiqc", mode: 'copy'] }
  withName: 'BWAMEM2_INDEX'       { publishDir = [ path: "${params.outdir}/bwamem2_index", mode: 'symlink'] }
  withName: 'BWAMEM2_MEM'         { publishDir = [ path: "${params.outdir}/bwamem2_mem", mode: 'copy'] }
  withName: 'MY_SAMTOOLS_VIEW'    { publishDir = [ path: "${params.outdir}/mysamtools", mode: 'symlink'] }
  withName: 'GET_REFERENCE_NAMES' { publishDir = [ path: "${params.outdir}/refname", mode: 'symlink' ] }
  withName: 'VIRAL_CONSENSUS'     { publishDir = [path: "${params.outdir}/viral_consensus", mode: 'copy'] }
}

manifest {
    name = 'j23414/unnamed'
    description = "Minor variant analysis pipeline tuned for our needs"
    version = "0.0"
}